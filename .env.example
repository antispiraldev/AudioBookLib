OPENAI_API_KEY=

# ElevenLabs — required only if a book uses a premium ElevenLabs narrator preset
# (multilingual_v2). Set on the worker droplet. NB: ElevenLabs caps *concurrent*
# requests per plan (often 5–15) — a premium book at SYNTH_CONCURRENCY 16 will 429.
ELEVENLABS_API_KEY=
# Gemini — only used by the A/B harness (scripts/tts_ab.py --round4); not in the
# production pipeline (Gemini returns PCM, the pipeline stores MP3).
GEMINI_API_KEY=

# PostgreSQL password (Docker Compose creates the DB with this).
# Required — compose refuses to start without it, deliberately: an earlier
# default meant production silently ran on a password published in this repo.
POSTGRES_PASSWORD=change-me

# Redis password (redis-server --requirepass). Required, same reasoning.
REDIS_PASSWORD=change-me

# Google OAuth (optional — omit to run without sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=change-me-openssl-rand-hex-32
ADMIN_EMAIL=you@example.com
# Comma-separated Google accounts allowed to sign in; empty = anyone
ALLOWED_EMAILS=
PUBLIC_BASE_URL=http://localhost

# Worker concurrency (worker droplet / docker-compose.worker.yml).
# SYNTH: network-bound TTS, ~110MB RAM per prefork slot (defaults to 8).
# INGEST: memory-heavy PyMuPDF — keep at 2 unless you add RAM (defaults to 2).
# EL: ElevenLabs premium narrators, on their own queue (defaults to 3). Set this
#     to your ElevenLabs plan's *concurrent request* limit or lower — exceeding
#     it is a 429, and capping it is why the queue is separate. Its slots cost
#     the same ~110MB each, so count them against the box's RAM alongside SYNTH.
#SYNTH_CONCURRENCY=8
#INGEST_CONCURRENCY=2
#EL_CONCURRENCY=3

# Cloudflare R2 (optional — omit to use local filesystem storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=audiobooklib
